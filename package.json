{
  "name": "peach-pi",
  "private": false,
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "predev": "node scripts/build-extensions.mjs",
    "dev": "DEV_TAP=1 pnpm --filter @peach-pi/desktop dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "package": "pnpm --filter @peach-pi/desktop package",
    "build:app": "bash scripts/build-app.sh",
    "make": "pnpm --filter @peach-pi/desktop make",
    "e2e": "pnpm --filter @peach-pi/desktop test:e2e",
    "devtap": "node scripts/devtap.mjs"
  },
  "pnpm": {
    "overrides": {
      "yauzl": "^3.3.1",
      "motion-dom": "12.38.0",
      "framer-motion": "12.38.0"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "fallow": "^2.103.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "catalog:"
  },
  "repository": "github:pechhe/peach-pi",
  "homepage": "https://github.com/pechhe/peach-pi",
  "bugs": {
    "url": "https://github.com/pechhe/peach-pi/issues"
  },
  "author": "pech-pi"
}
