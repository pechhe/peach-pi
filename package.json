{
  "name": "peach-pi",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @peach-pi/desktop dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "package": "pnpm --filter @peach-pi/desktop package",
    "build:app": "bash scripts/build-app.sh",
    "make": "pnpm --filter @peach-pi/desktop make",
    "e2e": "pnpm --filter @peach-pi/desktop test:e2e",
    "devtap": "node scripts/devtap.mjs"
  },
  "pnpm": {
    "overrides": {
      "yauzl": "^3.3.1"
    }
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "catalog:"
  }
}
