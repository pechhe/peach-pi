# Peach Pi environment variables.
# Copy to .env (root) for local dev, or set in CI/Release secrets.
# All telemetry/update features are OFF unless the relevant vars are set.

# ── Auto-update (app binary) ────────────────────────────────────────────────
# Base URL of the static manifest host (S3/R2/GCS). When set, the packaged app
# checks {url}/darwin/{arch}/RELEASES.json for new versions. Works with S3,
# Cloudflare R2, GCS, or any HTTPS static host.
# R2 example: https://peach-pi-uploads.<account>.r2.dev/peach-pi
PEACH_PI_UPDATE_URL=

# ── Auto-update publish target (Cloudflare R2 — S3-compatible) ──────────────
# Object storage credentials the CI publisher writes the ZIP + RELEASES.json
# to. R2 is S3-compatible; works because we set the endpoint + path-style.
# Stored in Bitwarden Secrets under PEACH_PI_R2_* keys.
# Bucket name (create the bucket first in Cloudflare R2 dashboard).
PEACH_PI_R2_BUCKET=
# Access key id + secret. R2: bucket API token with Object Read & Write.
PEACH_PI_R2_ACCESS_KEY_ID=
PEACH_PI_R2_SECRET_ACCESS_KEY=
# https://<account-id>.r2.cloudflarestorage.com
PEACH_PI_R2_S3_ENDPOINT=
# R2: set to "1" (R2 needs path-style URLs).
PEACH_PI_R2_FORCE_PATH_STYLE=1
# R2: set to "1" (R2 rejects ACL headers; public access via bucket setting).
PEACH_PI_R2_OMIT_ACL=1

# ── Crash reporting (Sentry) ────────────────────────────────────────────────
# Sentry DSN. Baked into the build by default (vite.main.config.ts ships the
# project DSN). Override only to self-host or rotate the ingest endpoint.
# Not a secret — it's a public ingest endpoint; can send events but can't read
# your data.
SENTRY_DSN=

# ── Product analytics (PostHog) ─────────────────────────────────────────────
# PostHog project key. VITE_ prefix bakes it into the renderer bundle at build
# time. Empty/absent → analytics disabled entirely.
VITE_POSTHOG_KEY=
# Optional: self-hosted PostHog host (default: https://app.posthog.com).
VITE_POSTHOG_HOST=

# ── macOS code signing + notarization ──────────────────────────────────────
# Apple Developer ID Application certificate identity (e.g. "Developer ID
# Application: Your Name (TEAMID)"). When set, Forge signs the .app.
PEACH_PI_SIGN_IDENTITY=
# Notarization (required since Catalina). When all three are set, Forge
# notarizes via notarytool. Use an app-specific password (not your Apple ID).
APPLE_ID=
APPLE_ID_PASSWORD=
APPLE_TEAM_ID=

# Optional: CI build number override (default: git short sha).
# PEACH_PI_BUILD_NUMBER=

# ── Dev / test ──────────────────────────────────────────────────────────────
# Override userData dir (test isolation).
# PEACH_PI_USER_DATA=
# Allow multiple app instances side-by-side (dev alongside packaged).
# PEACH_PI_ALLOW_MULTI_INSTANCE=1
